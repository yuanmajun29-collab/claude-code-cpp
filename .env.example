# ============================================================
# Claude Code C++ — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================================

# ---- Required ----
# Your Anthropic API key (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Model ----
# Model ID to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---- Permission Mode ----
# default = ask for each tool call
# bypass  = auto-allow all tool calls
# yolo    = skip all safety checks
CLAUDE_PERMISSION_MODE=default

# ---- Behavior ----
MAX_TOKENS=8192
MAX_ITERATIONS=100
# CLAUDE_THINKING=true
# THINKING_BUDGET=10000

# ---- Display ----
# CLAUDE_VERBOSE=true
# NO_COLOR=true

# ---- IDE Bridge ----
# Port for IDE Bridge HTTP/WebSocket server
BRIDGE_PORT=9876

# ---- MCP ----
# MCP_AUTH_TOKEN=your-mcp-token

# ---- Workspace ----
# Directory to mount as workspace (relative to project root)
WORKSPACE_DIR=./workspace

# ---- Security ----
# Uncomment to limit resource usage
# docker compose deploy resources limits memory 2G cpus 2.0
